# LLM
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ASR (leave SARVAM_API_KEY blank to use Whisper)
SARVAM_API_KEY=
WHISPER_MODEL=medium

# Storage (container paths — change for local dev)
CHROMA_PERSIST_PATH=./data/chroma
QUERY_LOG_PATH=./data/logs/queries.db
CORPUS_PATH=./ingestion/corpus

# Embeddings
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Pipeline thresholds
CRAG_CORRECT_THRESHOLD=0.5
CRAG_INCORRECT_THRESHOLD=0.2
RETRIEVAL_TOP_K=8
RETRIEVAL_FINAL_K=5
SELF_RAG_MAX_RETRIES=1

# App
LOG_LEVEL=INFO
APP_ENV=production
